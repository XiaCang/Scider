                },
                {
                  "type": "null"
                }
              ],
              "description": "年份上限（含）",
              "title": "Year To"
            }
          },
          {
            "name": "source_type",
            "in": "query",
            "description": "来源类型：conference | journal | arXiv",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "来源类型：conference | journal | arXiv",
              "title": "Source Type"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "排序：relevance | citations | date",
            "required": false,
            "schema": {
              "type": "string",
              "description": "排序：relevance | citations | date",
              "default": "relevance",
              "title": "Sort"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "headers": {}
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
