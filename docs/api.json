    "/api/user/login": {
      "post": {
        "summary": "登录",
        "deprecated": false,
        "description": "用户使用邮箱和密码进行身份验证。验证通过后会返回 Token供后续接口鉴权使用。\n- 验证逻辑：先根据 email 查询用户，若用户存在，则使用 bcrypt.compare(password, hash) 将明文密码与数据库密文进行比对。\n- 安全提示：无论邮箱不存在还是密码错误，建议统一返回“邮箱或密码错误”，以防恶意枚举账号。",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              },
              "example": {
                "email": "1282312174@qq.com",
                "password": "218218wcj"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "msg": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string"
                        },
                        "userInfo": {
                          "type": "object",
                          "properties": {
                            "userId": {
                              "type": "string"
                            },
                            "username": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "userId",
                            "username"
                          ]
                        }
                      },
                      "required": [
                        "token",
                        "userInfo"
                      ]
                    }
                  },
                  "required": [
                    "code",
